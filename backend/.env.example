APP_NAME="Sistema de Gestion de Acreditacion"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Lima

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=acreditacion
DB_USERNAME=root
DB_PASSWORD=

SANCTUM_STATEFUL_DOMAINS=localhost:9000,127.0.0.1:9000
SANCTUM_EXPIRATION_MINUTES=480
SESSION_DOMAIN=localhost
CORS_ALLOWED_ORIGINS=http://localhost:9000,http://127.0.0.1:9000

FILESYSTEM_DISK=s3
MAX_EVIDENCE_FILE_MB=500
ACCREDITATION_EXPORT_DISK=local
EVIDENCE_DIRECT_UPLOAD_ENABLED=true
EVIDENCE_DIRECT_UPLOAD_DISK=s3
EVIDENCE_DIRECT_UPLOAD_MAX_MB=2048
EVIDENCE_DIRECT_UPLOAD_THRESHOLD_MB=100
EVIDENCE_DIRECT_UPLOAD_EXPIRATION_MINUTES=15
EVIDENCE_VIDEO_TRANSCODING_ENABLED=false
FFMPEG_BINARY=ffmpeg

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sfo3
AWS_BUCKET=archivo
AWS_URL=https://archivo.sfo3.digitaloceanspaces.com
AWS_ENDPOINT=https://sfo3.digitaloceanspaces.com
AWS_USE_PATH_STYLE_ENDPOINT=false
